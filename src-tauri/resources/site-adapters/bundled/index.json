{
  "registry_version": 1,
  "adapters": [
    {
      "name": "36kr/newsflash",
      "domain": "www.36kr.com",
      "description": "采集 36Kr 快讯列表。",
      "read_only": true,
      "capabilities": ["newsflash", "research"],
      "args": [
        {
          "name": "limit",
          "description": "返回条目数量上限",
          "required": false,
          "arg_type": "integer",
          "example": 8
        }
      ],
      "example": "36kr/newsflash {\"limit\":8}",
      "entry": {
        "kind": "fixed_url",
        "url": "https://www.36kr.com/newsflashes"
      },
      "script_file": "scripts/36kr-newsflash.js",
      "source_version": "2026-03-25"
    },
    {
      "name": "bilibili/search",
      "domain": "search.bilibili.com",
      "description": "按关键词采集 B 站视频搜索结果。",
      "read_only": true,
      "capabilities": ["search", "video", "research"],
      "args": [
        {
          "name": "query",
          "description": "搜索关键词",
          "required": true,
          "arg_type": "string",
          "example": "AI Agent"
        },
        {
          "name": "limit",
          "description": "返回条目数量上限",
          "required": false,
          "arg_type": "integer",
          "example": 5
        }
      ],
      "example": "bilibili/search {\"query\":\"AI Agent\",\"limit\":5}",
      "entry": {
        "kind": "url_template",
        "template": "https://search.bilibili.com/all?keyword={{query|urlencode}}"
      },
      "script_file": "scripts/bilibili-search.js",
      "source_version": "2026-03-25"
    },
    {
      "name": "github/issues",
      "domain": "github.com",
      "description": "采集指定 GitHub 仓库的 issue 列表。",
      "read_only": true,
      "capabilities": ["issues", "repository", "research"],
      "args": [
        {
          "name": "repo",
          "description": "GitHub 仓库，格式 owner/name",
          "required": true,
          "arg_type": "string",
          "example": "rust-lang/rust"
        },
        {
          "name": "query",
          "description": "Issue 搜索关键词，可选",
          "required": false,
          "arg_type": "string",
          "example": "borrow checker"
        },
        {
          "name": "state",
          "description": "Issue 状态过滤，可选 open/closed/all",
          "required": false,
          "arg_type": "string",
          "example": "open"
        },
        {
          "name": "limit",
          "description": "返回条目数量上限",
          "required": false,
          "arg_type": "integer",
          "example": 5
        }
      ],
      "example": "github/issues {\"repo\":\"rust-lang/rust\",\"query\":\"borrow checker\",\"limit\":5}",
      "auth_hint": "私有仓库或受限 issue 需要先在浏览器中登录 GitHub。",
      "entry": {
        "kind": "builder",
        "id": "github_issues"
      },
      "script_file": "scripts/github-issues.js",
      "source_version": "2026-03-25"
    },
    {
      "name": "github/search",
      "domain": "github.com",
      "description": "按关键词采集 GitHub 仓库搜索结果。",
      "read_only": true,
      "capabilities": ["search", "repository", "research"],
      "args": [
        {
          "name": "query",
          "description": "搜索关键词",
          "required": true,
          "arg_type": "string",
          "example": "AI Agent"
        },
        {
          "name": "limit",
          "description": "返回条目数量上限",
          "required": false,
          "arg_type": "integer",
          "example": 5
        }
      ],
      "example": "github/search {\"query\":\"model context protocol\",\"limit\":5}",
      "auth_hint": "若需要访问更完整的搜索结果，请先在浏览器中登录 GitHub。",
      "entry": {
        "kind": "url_template",
        "template": "https://github.com/search?q={{query|urlencode}}&type=repositories"
      },
      "script_file": "scripts/github-search.js",
      "source_version": "2026-03-25"
    },
    {
      "name": "zhihu/hot",
      "domain": "www.zhihu.com",
      "description": "采集知乎热榜问题列表。",
      "read_only": true,
      "capabilities": ["hot", "feed", "research"],
      "args": [
        {
          "name": "limit",
          "description": "返回条目数量上限",
          "required": false,
          "arg_type": "integer",
          "example": 5
        }
      ],
      "example": "zhihu/hot {\"limit\":5}",
      "auth_hint": "请先在浏览器中登录知乎，再重试该命令。",
      "entry": {
        "kind": "fixed_url",
        "url": "https://www.zhihu.com/hot"
      },
      "script_file": "scripts/zhihu-hot.js",
      "source_version": "2026-03-25"
    },
    {
      "name": "zhihu/search",
      "domain": "www.zhihu.com",
      "description": "按关键词采集知乎搜索结果。",
      "read_only": true,
      "capabilities": ["search", "research"],
      "args": [
        {
          "name": "query",
          "description": "搜索关键词",
          "required": true,
          "arg_type": "string",
          "example": "AI Agent"
        },
        {
          "name": "limit",
          "description": "返回条目数量上限",
          "required": false,
          "arg_type": "integer",
          "example": 5
        }
      ],
      "example": "zhihu/search {\"query\":\"AI Agent\",\"limit\":5}",
      "auth_hint": "请先在浏览器中登录知乎，再重试该命令。",
      "entry": {
        "kind": "url_template",
        "template": "https://www.zhihu.com/search?type=content&q={{query|urlencode}}"
      },
      "script_file": "scripts/zhihu-search.js",
      "source_version": "2026-03-25"
    }
  ]
}
